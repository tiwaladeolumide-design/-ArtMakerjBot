# Required - Get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional - Get from replicate.com (Recommended - Best Quality)
REPLICATE_API_KEY=your_replicate_api_key_here

# Optional - Get from platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Optional - Get from huggingface.co (Free)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional - For receiving feedback notifications
ADMIN_CHAT_ID=your_telegram_user_id_here
